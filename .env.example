APP_NAME="Lunox Backfire"
APP_VERSION=2.3.0
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
API_URL=http://localhost:8000/api

# --------------------------------------------------------------------------
# API Authentication
# --------------------------------------------------------------------------
# APP_API_TOKEN  : Single static Bearer token untuk proteksi endpoint API.
# APP_API_TOKENS : Daftar token (comma-separated) untuk multi-consumer API.
#                  Jika APP_API_TOKENS diisi, APP_API_TOKEN akan diabaikan.
APP_API_TOKEN=your-secret-api-token
APP_API_TOKENS=

# --------------------------------------------------------------------------
# JWT Configuration
# --------------------------------------------------------------------------
# APP_JWT_SECRET : Kunci rahasia untuk signing JWT (HS256). Harus kuat!
#                  Generate: php backfire jwt:secret
# APP_JWT_TTL    : Masa aktif token JWT dalam detik (default: 3600 = 1 jam).
APP_JWT_SECRET=
APP_JWT_TTL=3600

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lunox_lite
DB_USERNAME=root
DB_PASSWORD=

MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --------------------------------------------------------------------------
# CORS Configuration [R4 Security Hardening]
# --------------------------------------------------------------------------
# CORS_ALLOWED_ORIGIN: Leave empty to BLOCK all cross-origin requests (safest).
# Set to '*' for public APIs without credentials.
# Set to a specific origin or comma-separated list for production:
#   CORS_ALLOWED_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGIN=
CORS_ALLOWED_METHODS=GET, POST, PUT, DELETE, OPTIONS
CORS_ALLOWED_HEADERS=Content-Type, Authorization, X-Requested-With, X-CSRF-TOKEN

